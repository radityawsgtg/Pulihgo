# Copy this file to `.env` (already gitignored) and fill in your Supabase
# project's values: Supabase dashboard -> Project Settings -> API.
#
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time by Expo —
# that's expected here: the "anon" key is meant to be public, it's the
# Supabase table's Row Level Security policies that actually restrict access.
# Never put the service_role key in an EXPO_PUBLIC_* var.
#
# Without this file, the app still runs fully offline — session sync to
# Supabase just no-ops with a console warning (see src/sync/supabaseClient.ts).

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
