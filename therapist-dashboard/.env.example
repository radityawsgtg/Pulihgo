# Copy this file to `.env` (already gitignored by Vite's default .gitignore)
# and fill in your Supabase project's values: Supabase dashboard -> Project
# Settings -> API. This is the SAME Supabase project pulihgo-app/ uploads
# sessions to — use the same URL, and the "anon" / "publishable" key (never
# the service_role key here; Vite inlines every VITE_* var into the browser
# bundle, so anything put here is publicly visible).
#
# Without this file, the dashboard still loads — Reports/Dashboard just show
# an error state instead of real session data (see src/lib/supabase.ts).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
